	<property name="ireport.zoom" value="1.4641000000000008"/>
	<property name="ireport.x" value="182"/>
	<property name="ireport.y" value="0"/>
	<parameter name="ADMIN_NAME" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT
            books.`id` AS books_id,
            books.`title` AS books_title,
            books.`author` AS books_author,
            books.`publisher` AS books_publisher,
            books.`origin` AS books_origin,
            books.`total_pages` AS books_total_pages,
            book_items.`code` AS book_items_code,
            categories.`id` AS categories_id,
            categories.`name` AS categories_name
        FROM books
        INNER JOIN book_items ON books.`id` = book_items.`book_id`
        INNER JOIN categories ON books.`category_id` = categories.`id`
        ORDER BY books.`id` ASC]]>
	</queryString>
	<field name="books_id" class="java.lang.Integer"/>
	<field name="books_title" class="java.lang.String"/>
	<field name="books_author" class="java.lang.String"/>
	<field name="books_publisher" class="java.lang.String"/>
	<field name="books_origin" class="java.lang.String"/>
	<field name="books_total_pages" class="java.lang.Integer"/>
	<field name="book_items_code" class="java.lang.String"/>
	<field name="categories_id" class="java.lang.Integer"/>
	<field name="categories_name" class="java.lang.String"/>
	<variable name="total_items_count" class="java.lang.Integer" resetType="Group" resetGroup="BookGroup" calculation="Count">
		<variableExpression><![CDATA[$F{book_items_code}]]></variableExpression>
	</variable>
