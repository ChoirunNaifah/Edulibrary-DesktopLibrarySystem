	<property name="ireport.zoom" value="1.331000000000012"/>
	<property name="ireport.x" value="360"/>
	<property name="ireport.y" value="0"/>
	<parameter name="PERIODE_TEXT" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[SELECT
     borrowings.`id` AS borrowings_id,
     students.`nisn` AS students_nisn,
     students.`name` AS students_name,
     students.`classroom` AS students_classroom,
     book_items.`code` AS book_items_code, -- Kode buku ditambahkan
     books.`title` AS books_title,
     categories.`name` AS categories_name,
     DATE_FORMAT(borrowings.`borrowed_at`, '%d %M %Y') AS borrowings_borrowed_at,
     DATE_FORMAT(borrowings.`returned_at`, '%d %M %Y') AS borrowings_returned_at,
     borrowings.`status` AS borrowings_status
FROM
     `books` books INNER JOIN `book_items` book_items ON books.`id` = book_items.`book_id`
     INNER JOIN `borrowing_details` borrowing_details ON book_items.`code` = borrowing_details.`book_code`
     INNER JOIN `borrowings` borrowings ON borrowing_details.`borrowing_id` = borrowings.`id`
     INNER JOIN `students` students ON borrowings.`student_nisn` = students.`nisn`
     INNER JOIN `categories` categories ON books.`category_id` = categories.`id`,
     `admins` admins]]>
	</queryString>
	<field name="borrowings_id" class="java.lang.Integer"/>
	<field name="students_nisn" class="java.lang.String"/>
	<field name="students_name" class="java.lang.String"/>
	<field name="students_classroom" class="java.lang.String"/>
	<field name="book_items_code" class="java.lang.String"/>
	<field name="books_title" class="java.lang.String"/>
